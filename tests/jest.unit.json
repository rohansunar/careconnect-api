{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": ".*\\.spec\\.ts$",
  "transform": {"^.+\\.(t|j)s$": "ts-jest"},
  "coverageDirectory": "./coverage/unit",
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  },
  "roots": ["<rootDir>/tests/"]
}
