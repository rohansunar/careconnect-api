enum NotificationStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

model Notification {
  id          String             @id @default(uuid())
  userID      String?
  user        User?             @relation(fields: [userID], references: [id])
  type        String
  message     String
  sent_via    String
  status      NotificationStatus @default(SENT)
  created_at  DateTime           @default(now())
}
