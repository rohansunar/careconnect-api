/// Enum representing the different types of ledger entries
enum LedgerType {
  /// Order completed - revenue from sale
  SALE
  /// Platform commission/fee
  PLATFORM_FEE
  /// Money returned to customer
  REFUND
  /// Settlement payout to vendor
  PAYOUT
}

/// Ledger model for tracking financial transactions between vendors and platform
model Ledger {
  /// Unique identifier for the ledger entry
  id           String   @id @default(cuid())

  /// Reference to the vendor
  vendorId     String
  vendor       Vendor   @relation(fields: [vendorId], references: [id])

  /// Reference to the order item
  orderItemId  String
  orderItem    OrderItem @relation(fields: [orderItemId], references: [id])

  /// Type of ledger transaction
  type         LedgerType

  /// Transaction amount
  amount       Decimal  @db.Decimal(10, 2)

  /// Payment mode used for the transaction
  paymentMode  PaymentMode

  /// Timestamp when the ledger entry was created
  createdAt    DateTime @default(now())

  /// Index for efficient vendor-based ledger queries
  @@index([vendorId])

  /// Index for efficient order item based ledger queries
  @@index([orderItemId])

  /// Index for efficient type-based filtering
  @@index([type])

  /// Index for efficient time-based queries
  @@index([createdAt])
}
