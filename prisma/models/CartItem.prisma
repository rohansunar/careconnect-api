model CartItem {
  /// Unique identifier for the cart item (auto-incrementing)
  id          Int      @id @default(autoincrement())

  /// Reference to the cart this item belongs to
  cartId      String
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  /// Reference to the product in the cart
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  /// Quantity of the product in cart (must be > 0)
  quantity    Int      @default(1)

  /// Price of the product at time of adding to cart (snapshotted)
  price       Decimal  @db.Decimal(10, 2)

  /// Deposit amount for the product at time of adding to cart (snapshotted)
  deposit     Decimal? @db.Decimal(10, 2)

  /// Timestamp when item was added to cart
  createdAt   DateTime @default(now())

  /// Timestamp when item was last updated
  updatedAt   DateTime @default(now())

  /// Prevent duplicate items in cart (same cart, product, and address)
  @@unique([cartId, productId])

  /// Index for efficient cart queries
  @@index([cartId])

  /// Index for efficient product-based queries
  @@index([productId])
}