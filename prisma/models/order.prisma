enum OrderStatus {
  PENDING
  CONFIRMED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMode {
  ONLINE
  COD
  MONTHLY
  SUBSCRIPTION
}

/**
 * CancellationOrigin enum for tracking who cancelled an order
 * Used in Order model to record cancellation source
 */
enum CancellationOrigin {
  CUSTOMER
  VENDOR
  RIDER
  ADMIN
}

model Order {
  id                    String   @id @default(uuid())
  orderNo               String   @unique
  userId            String
  vendorId              String
  addressId             String
  cartId                String?
  total_amount          Decimal  @db.Decimal(10, 2)
  payment_status        String   @db.VarChar(32) @default("PENDING")
  riderId              String?
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now())
  payment_mode          PaymentMode
  subscriptionId        String? // Link to subscription for scheduled orders
  delivery_status       OrderStatus  @default(PENDING) // PENDING, DELIVERED, FAILED, etc.
  delivery_otp          String?
  otp_verified          Boolean @default(false)
  otp_generated_at      DateTime?
  cancelledAt           DateTime?
  cancelReason          String?
  cancellation_origin   CancellationOrigin? // Who cancelled the order: CUSTOMER, VENDOR, RIDER, ADMIN
  paymentId             String?
  payment               Payment? @relation("orderPayment", fields: [paymentId], references: [id])

  @@index([orderNo])
  @@index([riderId])
  @@index([vendorId, delivery_status])
}