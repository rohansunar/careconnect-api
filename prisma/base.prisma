generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // or whatever
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum MonthlyBillStatus {
  PENDING
  PAID
  OVERDUE
}
enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

