generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // or whatever
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum MonthlyBillStatus {
  PENDING
  PAID
  OVERDUE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentLinkStatus {
  ACTIVE
  EXPIRED
  USED
}




model Categories {
  id         String    @id @default(uuid())
  name       String
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  products   Product[]

  /// Constraints & indexes
  @@unique([name])
}


model City {
  id         String   @id @default(uuid())
  name       String
  state      String?
  country    String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt()

  vendors           Vendor[]
  customerAddresses CustomerAddress[]
}

// bbox      Unsupported("geometry")


model Customer {
  id         String   @id @default(uuid())
  name       String
  phone      String   @unique
  email      String?
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  ///  notifications Notification[]
  customer_addresses CustomerAddress[]
  notifications      Notification[]
}


model CustomerAddress {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label      String?
  address    String?
  cityId     String?
  city       City?    @relation(fields: [cityId], references: [id])
  pincode    String?
  created_at DateTime @default(now())

  /// orders      Order[] @relation("orders")
  subscriptions Subscription[]
}

// location    Unsupported("geometry(POINT, 4326)")


enum NotificationStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

model Notification {
  id          String             @id @default(uuid())
  customer_id String?
  customer    Customer?          @relation(fields: [customer_id], references: [id])
  vendor_id   String?
  vendor      Vendor?            @relation(fields: [vendor_id], references: [id])
  type        String
  message     String
  sent_via    String
  status      NotificationStatus @default(SENT)
  created_at  DateTime           @default(now())
}


enum OtpPurpose {
  VENDOR_LOGIN
  CUSTOMER_LOGIN
  DELIVERY_VERIFICATION
  PASSWORD_RESET
}

model OtpCode {
  id        String     @id @default(uuid())
  phone     String
  code      String
  purpose   OtpPurpose
  expiresAt DateTime
  attempts  Int        @default(0)
  isUsed    Boolean    @default(false)
  createdAt DateTime   @default(now())
  usedAt    DateTime?

  @@unique([phone, purpose])
}


model Product {
  id         String @id @default(uuid())
  name       String
  categoryId String

  /// Relation to Categories (on delete -> CASCADE)
  categories  Categories @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  image_url   String?
  description String?
  created_at  DateTime   @default(now())
  vendorId     String
  vendor      Vendor     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  price       Decimal  @db.Decimal(10, 2)  
  deposit     Decimal?  @db.Decimal(10, 2) 
  is_active   Boolean    @default(true)
  updated_at  DateTime   @default(now())

  /// subscriptions Subscription[]
  subscriptions Subscription[]

  @@index([categoryId])
}


enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  PENDING
}

model Subscription {
  id                 String             @id @default(uuid())
  customerAddressId  String?
  customerAddress    CustomerAddress?   @relation(fields: [customerAddressId], references: [id])
  vendorId           String?
  vendor             Vendor?            @relation(fields: [vendorId], references: [id])
  productId          String?
  product            Product?           @relation(fields: [productId], references: [id])
  jars_per_delivery  Int
  frequency          String
  next_delivery_date DateTime?
  status             SubscriptionStatus @default(ACTIVE)
  created_at         DateTime           @default(now())
  updated_at         DateTime           @default(now())

  @@index([customerAddressId])
  @@index([vendorId])
  @@index([productId])
}


model Vendor {
  id                 String   @id @default(uuid())
  name               String
  owner_name         String?
  phone              String   @unique
  email              String?
  address            Json?
  ///  city_id   String?
  ///  city      City?    @relation(fields: [city_id], references: [id])
  pincode            String?
  location           String?
  is_active          Boolean  @default(true)
  is_available_today Boolean  @default(true)
  service_radius_m   Int?
  delivery_time_msg  String?
  created_at         DateTime @default(now())
  updated_at         DateTime @default(now())

  ///  subscriptions Subscription[]
  ///  monthly_bills MonthlyBill[]
  ///  payments Payment[]
  ///  notifications Notification[]
  ///  products Product[] @relation("products")
  ///  orders Order[] @relation("orders")
  products      Product[]
  city          City?          @relation(fields: [cityId], references: [id])
  cityId        String?
  subscriptions Subscription[]
  notifications Notification[]
}
