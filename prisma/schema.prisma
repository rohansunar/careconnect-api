generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // or whatever
  url      = env("DATABASE_URL")
}

enum MonthlyBillStatus {
  PENDING
  PAID
  OVERDUE
}


enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
}

model Cart {
  /// Unique identifier for the cart
  id         String     @id @default(uuid())

  /// Reference to the customer who owns this cart
  customerId String
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  /// Status of the cart
  status     CartStatus @default(ACTIVE)

  /// Timestamp when cart was created
  createdAt  DateTime   @default(now())

  /// Timestamp when cart was last updated
  updatedAt  DateTime   @default(now())

  /// Cart items in this cart
  cartItems  CartItem[]
  orders     Order[] @relation("orders")

  /// Index for efficient customer cart queries
  @@index([customerId])
}

model CartItem {
  id          String     @id @default(uuid())
  cartId      String
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  /// Reference to the product in the cart
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  /// Quantity of the product in cart (must be > 0)
  quantity    Int      @default(1)

  /// Price of the product at time of adding to cart (snapshotted)
  price       Decimal  @db.Decimal(10, 2)

  /// Deposit amount for the product at time of adding to cart (snapshotted)
  deposit     Decimal? @db.Decimal(10, 2)

  /// Timestamp when item was added to cart
  createdAt   DateTime @default(now())

  /// Timestamp when item was last updated
  updatedAt   DateTime @default(now())

  /// Prevent duplicate items in cart (same cart, product, and address)
  @@unique([cartId, productId])

  /// Index for efficient cart queries
  @@index([cartId])

  /// Index for efficient product-based queries
  @@index([productId])
}

enum admin_role {
  admin
  super_admin
  staff
  support
}

model Admin {
  id            String      @id @default(uuid())
  name          String      @db.VarChar(100)
  email         String      @unique @db.VarChar(150)
  password_hash String      @db.Text
  role          admin_role
  is_active     Boolean     @default(true)
  phone         String?     @db.VarChar(20)
  created_at    DateTime    @default(now()) @db.Timestamp
  updated_at    DateTime    @default(now()) @db.Timestamp
}


model BankAccount {
  id                String   @id @default(uuid())
  vendorId          String
  vendor            Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  accountNumber      String
  ifscCode           String
  bankName           String
  accountHolderName  String
  upiId             String?
  isDefault          Boolean  @default(false)
  isVerified         Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now())

  /// Constraints & indexes
  @@index([vendorId])
  @@unique([accountNumber])
}


model Categories {
  id         String    @id @default(uuid())
  name       String
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  products   Product[]

  /// Constraints & indexes
  @@unique([name])
}


model City {
  id         String   @id @default(uuid())
  name       String
  state      String?
  country    String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt()

  vendors           Vendor[]
  customerAddresses CustomerAddress[]
}

// bbox      Unsupported("geometry")


model Counter {
  id          String @id @default(uuid())
  type        String @unique
  lastNumber  Int    @default(0)
}

model Customer {
  id         String   @id @default(uuid())
  name       String
  phone      String   @unique
  email      String?
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  addresses CustomerAddress[]
  notifications  Notification[]
  carts Cart[]
  orders Order[] @relation("orders")
  monthlyBills MonthlyBill[]
  payments Payment[]
}


model CustomerAddress {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label      String?
  address    String?
  cityId     String?
  city       City?    @relation(fields: [cityId], references: [id])
  pincode    String?
  created_at DateTime @default(now())
  isDefault Boolean   @default(false)
  isActive   Boolean   @default(true)

  /// orders      Order[] @relation("orders")
  subscriptions Subscription[]
  orders Order[] @relation("orders")
  @@index([customerId])

}

// location    Unsupported("geometry(POINT, 4326)")

model MonthlyBill {
  id            String   @id @default(uuid())
  customer_id   String?
  customer      Customer? @relation(fields: [customer_id], references: [id])
  vendor_id     String?
  vendor        Vendor? @relation(fields: [vendor_id], references: [id])
  month         String
  total_amount  Decimal  @db.Decimal(10, 2)
  paid_amount   Decimal  @db.Decimal(10, 2) @default(0)
  status        MonthlyBillStatus @default(PENDING)
  generated_at  DateTime @default(now())
  updated_at    DateTime @default(now())
}

enum NotificationStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

model Notification {
  id          String             @id @default(uuid())
  customer_id String?
  customer    Customer?          @relation(fields: [customer_id], references: [id])
  vendor_id   String?
  vendor      Vendor?            @relation(fields: [vendor_id], references: [id])
  type        String
  message     String
  sent_via    String
  status      NotificationStatus @default(SENT)
  created_at  DateTime           @default(now())
}


enum OrderStatus {
  PENDING
  PAID
  CONFIRMED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model Order {
  id                    String   @id @default(uuid())
  orderNo               String   @unique
  customerId            String?
  customer              Customer? @relation("orders", fields: [customerId], references: [id])
  vendorId              String?
  vendor                Vendor? @relation("orders", fields: [vendorId], references: [id])
  addressId             String?
  address               CustomerAddress? @relation("orders", fields: [addressId], references: [id])
  cartId                String?
  cart                  Cart? @relation("orders", fields: [cartId], references: [id])
  total_amount          Decimal  @db.Decimal(10, 2)
  status                String   @db.VarChar(32) @default("PENDING")
  payment_status        String   @db.VarChar(32) @default("PENDING")
  assigned_rider_phone  String?
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now())
  cancelledAt           DateTime?
  cancelReason          String?


  payments Payment[]
  @@index([orderNo])
}

enum OtpPurpose {
  VENDOR_LOGIN
  CUSTOMER_LOGIN
  DELIVERY_VERIFICATION
  PASSWORD_RESET
}

model OtpCode {
  id        String     @id @default(uuid())
  phone     String
  code      String
  purpose   OtpPurpose
  expiresAt DateTime
  attempts  Int        @default(0)
  isUsed    Boolean    @default(false)
  createdAt DateTime   @default(now())
  usedAt    DateTime?

  @@unique([phone, purpose])
}


enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUND_INITIATED
  REFUNDED
}

model Payment {
  id                    String   @id @default(uuid())
  order_id              String?
  order                 Order? @relation(fields: [order_id], references: [id])
  customer_id           String?
  customer              Customer? @relation(fields: [customer_id], references: [id])
  vendor_id             String?
  vendor                Vendor? @relation(fields: [vendor_id], references: [id])
  amount                Decimal  @db.Decimal(12, 2)
  currency              String   @default("INR")
  payment_mode          String
  provider              String?
  provider_payment_id   String?
  provider_payload      Json?
  status                PaymentStatus @default(PENDING)
  initiated_at          DateTime @default(now())
  completed_at          DateTime?
  reconciled            Boolean  @default(false)
  metadata              Json?
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now())
}

model Product {
  id          String @id @default(uuid())
  name        String
  categoryId  String

  /// Relation to Categories (on delete -> CASCADE)
  categories  Categories @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  images      String[]
  description String?
  created_at  DateTime   @default(now())
  vendorId    String
  vendor      Vendor     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  price       Decimal  @db.Decimal(10, 2)  
  deposit     Decimal?  @db.Decimal(10, 2) 
  is_active   Boolean    @default(true)
  updated_at  DateTime   @default(now())

  subscriptions Subscription[]
  cartItems CartItem[]
  @@index([categoryId])
}


model Rider {
  id         String   @id @default(uuid())
  name       String
  phone      String   @unique
  email      String?
  address    String?
  vendorId  String?
  vendor     Vendor?  @relation(fields: [vendorId], references: [id])
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  PENDING
}

model Subscription {
  id                 String             @id @default(uuid())
  customerAddressId  String?
  customerAddress    CustomerAddress?   @relation(fields: [customerAddressId], references: [id])
  vendorId           String?
  vendor             Vendor?            @relation(fields: [vendorId], references: [id])
  productId          String?
  product            Product?           @relation(fields: [productId], references: [id])
  jars_per_delivery  Int
  frequency          String
  next_delivery_date DateTime?
  status             SubscriptionStatus @default(ACTIVE)
  created_at         DateTime           @default(now())
  updated_at         DateTime           @default(now())

  @@index([customerAddressId])
  @@index([vendorId])
  @@index([productId])
}


model Vendor {
  id                 String   @id @default(uuid())
  vendorNo           String   @unique
  name               String
  owner_name         String?
  phone              String   @unique
  email              String?
  address            Json?
  cityId             String?
  city      City?    @relation(fields: [cityId], references: [id])
  pincode            String?
  location           String?
  is_active          Boolean  @default(true)
  is_available_today Boolean  @default(true)
  service_radius_m   Int?
  delivery_time_msg  String?
  created_at         DateTime @default(now())
  updated_at         DateTime @default(now())
  @@index([vendorNo])

  products           Product[]
  subscriptions      Subscription[]
  notifications      Notification[]
  bankAccounts       BankAccount[]
  orders             Order[] @relation("orders")
  monthlyBills       MonthlyBill[]
  payments           Payment[]
  riders             Rider[]
}
